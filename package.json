{
  "name": "lemon-captcha",
  "version": "0.1.1",
  "description": "Zero-dependency SVG CAPTCHA generation engine for Node.js, Deno, Bun, and edge runtimes",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.txt"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sametlprsln/lemon-captcha.git"
  },
  "keywords": [
    "captcha",
    "svg",
    "typescript",
    "security",
    "bot-protection"
  ],
  "license": "MIT"
}
